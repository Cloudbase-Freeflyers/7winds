# MongoDB Atlas connection string. Format:
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=7winds

# Password used to gate the /admin page (HTTP Basic auth, username can be anything).
ADMIN_PASSWORD=change-me

# Public site config — exposed to the browser.
NEXT_PUBLIC_SITE_URL=https://7windsparagliding.com
NEXT_PUBLIC_WHATSAPP_NUMBER=972500000000
NEXT_PUBLIC_PHONE_NUMBER=+972-50-000-0000
NEXT_PUBLIC_YOUTUBE_VIDEO_ID=dQw4w9WgXcQ

# Tracking — leave blank to disable. Scripts are only injected when set.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Anthropic Claude API key — used for voice note transcription and AI features.

ANTHROPIC_API_KEY=
