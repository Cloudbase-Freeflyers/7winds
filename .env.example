# MongoDB Atlas connection string. Format:
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Database name (defaults to 7winds if unset)
MONGODB_DB=7winds

# Password used to gate the /admin page (HTTP Basic auth, username can be anything).
ADMIN_PASSWORD=change-me

# Secret used to sign affiliate login session cookies.
# Use a long random string in production (different from ADMIN_PASSWORD).
AFFILIATE_SESSION_SECRET=change-me-affiliate-session

# Public site config — exposed to the browser.
NEXT_PUBLIC_SITE_URL=https://7windsparagliding.com
NEXT_PUBLIC_WHATSAPP_NUMBER=972515152637
NEXT_PUBLIC_PHONE_NUMBER=0515152637
NEXT_PUBLIC_YOUTUBE_VIDEO_ID=dQw4w9WgXcQ

# Tracking — leave blank to disable. Scripts are only injected when set.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Anthropic Claude API key — used for voice note transcription and AI features.
ANTHROPIC_API_KEY=

# iCount hosted pay page — amount/description passed dynamically via cs/cd params
ICOUNT_PAYPAGE_URL=https://app.icount.co.il/m/b6637/cddddp14u6a286215c7

# Optional: separate iCount pay page URL for group bookings
ICOUNT_GROUP_PAYPAGE_URL=
