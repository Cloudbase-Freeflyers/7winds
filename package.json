{
    "name": "7winds-landing",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "typecheck": "tsc --noEmit",
        "setup-db": "node scripts/setup-db.mjs",
        "gmail-oauth": "node scripts/gmail-oauth.mjs",
        "test:email": "node scripts/test-email-config.mjs",
        "clasp:login": "clasp login",
        "clasp:create": "cd apps-script && clasp create --type standalone --title \"7Winds Email\" --rootDir .",
        "clasp:push": "cd apps-script && clasp push",
        "clasp:open": "cd apps-script && clasp open",
        "clasp:deploy": "cd apps-script && clasp deploy --description \"7Winds email webapp\""
    },
    "dependencies": {
        "@xenova/transformers": "^2.17.2",
        "clsx": "^2.1.1",
        "googleapis": "^173.0.0",
        "html2canvas": "^1.4.1",
        "jspdf": "^4.2.1",
        "mongodb": "^6.10.0",
        "next": "^15.0.3",
        "qrcode": "^1.5.4",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/node": "^22.9.0",
        "@types/qrcode": "^1.5.6",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "autoprefixer": "^10.4.20",
        "eslint": "^9.15.0",
        "eslint-config-next": "^15.0.3",
        "@google/clasp": "^2.5.0",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.15",
        "typescript": "^5.6.3"
    }
}
